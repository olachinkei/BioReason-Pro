{
  "default_asset_group": "all",
  "asset_groups": {
    "comparison-model-family": [
      "bioreason-pro-rl-paper"
    ],
    "benchmark-ia": [
      "disease-temporal-ia-main",
      "disease-temporal-ia-comparison"
    ],
    "all": [
      "bioreason-pro-rl-paper",
      "disease-temporal-ia-main",
      "disease-temporal-ia-comparison"
    ]
  },
  "assets": {
    "bioreason-pro-rl-paper": {
      "display_name": "bioreason-pro-rl-paper",
      "artifact_name": "bioreason-pro-rl-paper",
      "artifact_type": "model",
      "registry_env_var": "BIOREASON_RL_PAPER_MODEL_REGISTRY_PATH",
      "artifact_aliases": [
        "production",
        "latest",
        "{benchmark_alias}"
      ],
      "sources": [
        {
          "type": "local_dir",
          "local_dir": "${BIOREASON_RL_PAPER_MODEL_SOURCE_DIR}",
          "required_paths": [
            "config.json",
            "go_embedding.pt",
            "go_projection.pt",
            "protein_projection.pt",
            "protein_model/pytorch_model.bin"
          ]
        },
        {
          "type": "huggingface",
          "repo_id_env": "BIOREASON_PRO_RL_HF_REPO",
          "local_dir": "data/artifacts/models/bioreason_pro_rl_paper",
          "required_paths": [
            "config.json",
            "go_embedding.pt",
            "go_projection.pt",
            "protein_projection.pt",
            "protein_model/pytorch_model.bin"
          ]
        }
      ]
    },
    "disease-temporal-ia-main": {
      "display_name": "disease-temporal-ia-main",
      "artifact_name": "disease-temporal-ia",
      "artifact_type": "dataset",
      "registry_env_var": "BIOREASON_MAIN_IA_REGISTRY_PATH",
      "artifact_aliases": [
        "production",
        "{benchmark_alias}"
      ],
      "sources": [
        {
          "type": "local_path",
          "local_path": "${BIOREASON_MAIN_IA_SOURCE_PATH}"
        }
      ]
    },
    "disease-temporal-ia-comparison": {
      "display_name": "disease-temporal-ia-comparison",
      "artifact_name": "disease-temporal-ia",
      "artifact_type": "dataset",
      "registry_env_var": "BIOREASON_COMPARISON_IA_REGISTRY_PATH",
      "artifact_aliases": [
        "{benchmark_alias}"
      ],
      "sources": [
        {
          "type": "local_path",
          "local_path": "${BIOREASON_COMPARISON_IA_SOURCE_PATH}"
        }
      ]
    }
  }
}
